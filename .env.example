# Coaching brain runs on NVIDIA's free endpoint (get a key at build.nvidia.com).
EXPO_PUBLIC_NVIDIA_API_KEY=your_nvidia_nvapi_key_here
# Optional model override; defaults to z-ai/glm-5.2 (fast + reliable).
EXPO_PUBLIC_NVIDIA_MODEL=z-ai/glm-5.2
EXPO_PUBLIC_REVENUECAT_IOS_KEY=your_revenuecat_key_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here 
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here 
